# Copiá este archivo a .env y completá los valores.
# cp .env.example .env

# Token del túnel de Cloudflare (Zero Trust → Networks → Tunnels → tu túnel → Docker).
# Solo necesario si vas a usar el perfil "tunnel".
TUNNEL_TOKEN=

# Origen permitido para CORS en la API. Para un leaderboard público podés dejar "*".
# Para restringir, poné tu dominio, p. ej. https://juego.tudominio.com
CORS_ORIGIN=*
